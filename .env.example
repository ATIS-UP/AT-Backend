# ============================================
# CONFIGURACIÓN DEL BACKEND - SISTEMA DE ALERTAS TEMPRANAS
# ============================================
# Copia este archivo como .env y completa los valores

# ===== Database (Neon PostgreSQL) =====
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=require

# ===== JWT Configuration =====
JWT_SECRET_KEY=your_super_secret_key_min_32_characters
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===== Fernet Encryption (datos sensibles) =====
# Generar nueva clave: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_key_here

# ===== App Configuration =====
APP_NAME=Sistema de Alertas Tempranas
APP_VERSION=1.0.0
DEBUG=false
CORS_ORIGIN=http://localhost:5173

# ===== Rate Limiting =====
LOGIN_RATE_LIMIT_PER_MINUTE=5
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ===== Email Configuration (SMTP) =====
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password

# ===== Cloud Storage (AWS S3) =====
# AWS_ACCESS_KEY_ID=your_access_key
# AWS_SECRET_ACCESS_KEY=your_secret_key
# AWS_BUCKET_NAME=at-artefactos
# AWS_REGION=us-east-1

# ===== Logging =====
LOG_LEVEL=INFO
LOG_FILE=logs/app.log